# HR 智能问答系统 - 环境变量示例
# API 配置主要在应用内「设置」页面完成，以下为可选首次启动默认值

# 可选：首次启动时的默认 API 地址（未设置则用 SiliconFlow 默认地址）
# API_INITIAL_URL="https://api.siliconflow.cn/v1"

# 可选：首次启动时的默认 API Key（未设置则为空，需在设置页面配置）
# API_INITIAL_KEY=""

# ------------------------------
# 可选：第三方登录（生产接入时配置）
# ------------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# WECHAT_CORP_ID=""
# WECHAT_AGENT_ID=""
# WECHAT_AGENT_SECRET=""
# FEISHU_APP_ID=""
# FEISHU_APP_SECRET=""
# SSO_REDIRECT_BASE_URL="https://your-domain.com"
# 本地联调扫码 mock（生产务必关闭）
# SSO_MOCK_ENABLED="true"
# SSO_MOCK_KEY=""
